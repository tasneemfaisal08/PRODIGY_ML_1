import docx
import json
from docx.document import Document
from docx.table import Table
from docx.text.paragraph import Paragraph

def extract_no_limits(file_path):
    doc = docx.Document(file_path)
    final_output = []

    current_section = {"section": "بداية الملف", "text": ""}


    def is_real_header(t):
        headers = ["مادة (", "جدول رقم", "المستوى الدراسي", "توصيف مقرر"]
        return any(t.startswith(h) for h in headers)


    for block in iter_block_items(doc): # استخدمي الدالة اللي بتجيب Paragraph و Table بالترتيب
        if isinstance(block, Paragraph):
            text = block.text.strip()
            if not text: continue

            # لو لقينا بداية مادة جديدة، نسيف اللي فات ونبدأ جديد
            if is_real_header(text):
                final_output.append(current_section)
                current_section = {"section": text, "text": ""}
            else:
                current_section["text"] += text + "\n"

        elif isinstance(block, Table):
            # تحويل الجدول لـ Markdown مهما كان حجمه
            table_md = "\n"
            for i, row in enumerate(block.rows):
                cells = [c.text.strip().replace("\n", " ") for c in row.cells]
                table_md += "| " + " | ".join(cells) + " |\n"
                if i == 0:
                    table_md += "| " + " | ".join(["---"] * len(cells)) + " |\n"
            current_section["text"] += table_md + "\n"

    final_output.append(current_section) # إضافة آخر جزء
    return final_output


data = extract_no_limits('/content/AI_Bylaw.docx')
with open("draft1_COMPREHENSIVE_BYLAW.json", "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False, indent=4)
